{
  "name": "hd-platform",
  "version": "1.0.0",
  "description": "HD Platform Business OS",
  "main": "main.js",
  "author": "Hirusha Divisekara",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "nexe": "^5.0.0-beta.4"
  },
  "build": {
    "appId": "com.hd.platform",
    "productName": "HD Platform",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "electron-window-state": "^5.0.3"
  }
}
